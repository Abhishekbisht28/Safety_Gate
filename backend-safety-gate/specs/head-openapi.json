{
  "openapi": "3.0.0",
  "paths": {
    "/choutbound-service/v1/manual-push-count": {
      "get": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subscriber_name": { "type": "string" },
                  "manual_push_by": { "type": "integer" }
                },
                "required": ["manual_push_by"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "push_count": { "type": "string" },
                    "subscriber_name": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/choutbound-service/v1/content/draft": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" }
                },
                "required": ["title"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "draft_id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
